<section id="contacto" class="section">
    <div class="container footer-grid fade-up">
        <div class="f-info">
            <h2 class="serif">Visítanos.</h2>
            <div class="contact-details">
                <p><strong>Dirección</strong><br>Av. Chapultepec Sur 123<br>Col. Americana, Guadalajara</p>
                <p><strong>Teléfono</strong><br>+52 33 3492 2117</p>
                <p><strong>Horario</strong><br>Lun - Vie: 9am - 8pm<br>Sábados: 9am - 5pm</p>
            </div>
            <div class="socials">
                <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="#" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>
            </div>
        </div>
        <div class="f-map">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3732.8822059270565!2d-103.37097482475308!3d20.674370780887667!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8428ae053e7536fb%3A0x40303f573da61e1!2sAv.%20Chapultepec%20Sur%20123%2C%20Col%20Americana%2C%20Americana%2C%2044150%20Guadalajara%2C%20Jal.!5e0!3m2!1sen!2smx!4v1774295950022!5m2!1sen!2smx" width="100%" height="100%" style="border:0; filter: grayscale(1) invert(0.9);" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </div>
</section>
<footer class="footer fade-up">
    <div class="container">
        <p>&copy; 2026 Estética Vero. Todos los derechos reservados.</p>
    </div>
</footer>
<style>
.footer-grid {
    display: flex; flex-direction: column; gap: 4rem;
}
.f-info h2 { font-size: 4rem; margin-bottom: 2rem; }
.contact-details { display: grid; grid-template-columns: 1fr; gap: 2rem; margin-bottom: 3rem; }
.contact-details p { font-size: 0.95rem; }
.contact-details strong { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; color: var(--accent); display: block; margin-bottom: 0.5rem; }
.socials a { font-size: 1.5rem; margin-right: 1.5rem; color: var(--text-dark); transition: color 0.3s; }
.socials a:hover { color: var(--accent); }
.f-map { height: 400px; width: 100%; }

.footer { padding: 2rem 0; text-align: center; font-size: 0.8rem; letter-spacing: 1px; color: #888; border-top: 1px solid var(--accent-light); margin-top: 4rem; }

@media (min-width: 768px) {
    .footer-grid { flex-direction: row; justify-content: space-between; }
    .f-info { width: 40%; }
    .f-map { width: 55%; height: 500px; }
    .contact-details { grid-template-columns: 1fr 1fr; }
}
</style>
