---
---
<section id="galeria" class="section">
    <div class="container">
        <h2 class="serif section-mid-title fade-up">Portafolio</h2>
        <div class="gallery-masonry">
            <div class="img-box box-1 fade-up"><img src="/images/gallery1.png" alt="Hair styling"></div>
            <div class="img-box box-2 fade-up" style="transition-delay: 0.1s"><img src="/images/avatar2.png" alt="Balayage"></div>
            <div class="img-box box-3 fade-up" style="transition-delay: 0.2s"><img src="/images/avatar3.png" alt="Makeup"></div>
            <div class="img-box box-4 fade-up" style="transition-delay: 0.3s"><img src="/images/salon.png" alt="Interior"></div>
        </div>
    </div>
</section>
<style>
.section-mid-title {
    font-size: clamp(3rem, 5vw, 4rem);
    text-align: center;
    margin-bottom: 5rem;
    font-style: italic;
}
.gallery-masonry {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 100px;
    gap: 1.5rem;
}
.img-box {
    overflow: hidden;
}
.img-box img {
    width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(100%); transition: filter 1s ease, transform 1s ease;
}
.img-box:hover img {
    filter: grayscale(0%);
    transform: scale(1.05);
}

/* Broken grid layout */
.box-1 { grid-column: 1 / 13; grid-row: span 3; }
.box-2 { grid-column: 1 / 13; grid-row: span 4; }
.box-3 { grid-column: 1 / 13; grid-row: span 4; }
.box-4 { grid-column: 1 / 13; grid-row: span 3; }

@media (min-width: 768px) {
    .gallery-masonry { grid-auto-rows: 120px; gap: 2rem; }
    .box-1 { grid-column: 1 / 7; grid-row: span 4; }
    .box-2 { grid-column: 8 / 13; grid-row: span 3; margin-top: 4rem; }
    .box-3 { grid-column: 2 / 6; grid-row: span 5; margin-top: -2rem; }
    .box-4 { grid-column: 7 / 13; grid-row: span 4; }
}
</style>
